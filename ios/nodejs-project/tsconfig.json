{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noErrorTruncation": true,
    "paths": {
      "*": ["./types", "./node_modules/@digidem/types/vendor/*/index.d.ts"]
    },
    "noEmit": true
  },
  "include": ["**/*"],
  "exclude": ["node_modules"]
}
