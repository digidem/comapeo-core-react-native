{
  "extends": ["./tsconfig.json"],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "jsx": "react-native",
    "module": "esnext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "./build",
    "sourceMap": true,
    "target": "esnext"
  },
  "include": ["src/**/*"]
}
