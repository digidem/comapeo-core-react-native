<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--  Request notification permission to be able to show the foreground service notification  -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        `extractNativeLibs="false"`: native libraries (libnode.so + every
        per-addon `lib<name>__<version>.so` in `jniLibs/<abi>/`) ship
        uncompressed and aligned inside the APK and Bionic mmaps them in
        place at load time — no extraction to nativeLibraryDir. Required
        by the rolled-up backend's bare-name `process.dlopen` calls; a
        full-path dlopen would fail because nativeLibraryDir is empty
        under this configuration. Pairs with
        `packagingOptions.jniLibs.useLegacyPackaging = false` in
        build.gradle.
    -->
    <application
        android:extractNativeLibs="false">
        <!-- android:name should not change (see http://android-developers.blogspot.com/2011/06/things-that-cannot-change.html) -->
        <!-- android:process is used to run the service in a separate process -->
        <!-- android:exported stops other apps from starting this service -->
        <!-- android:foregroundServiceType see https://developer.android.com/develop/background-work/services/fgs/service-types#data-sync -->
        <service
            android:name=".ComapeoCoreService"
            android:process=":ComapeoCore"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!--
            Streams blob/icon bytes from the backend's UDS-bound HTTP server
            as `content://${applicationId}.comapeo.media/...` URIs.
            `exported=false`: only this app can target the provider.
            `grantUriPermissions=true`: a future share-sheet flow can hand a
            one-shot read grant to another app via FLAG_GRANT_READ_URI_PERMISSION
            without reopening the provider.
            Runs in the **main** app process (no `android:process`) — the
            ComapeoCore service process binds the socket; the main process
            connects to it from this provider.
        -->
        <provider
            android:name="com.comapeo.core.media.MediaContentProvider"
            android:authorities="${applicationId}.comapeo.media"
            android:exported="false"
            android:grantUriPermissions="true"/>
    </application>
</manifest>
