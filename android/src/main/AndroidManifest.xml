<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--  Request notification permission to be able to show the foreground service notification  -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        BLE peer discovery (docs/ble-discovery.md). Marked not-required:
        the module degrades to mDNS-only discovery on hardware without BLE.
    -->
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />
    <!--
        API 31+ "Nearby devices" runtime group. BLUETOOTH_SCAN carries
        `neverForLocation`: CoMapeo never derives location from scan
        results (RSSI is only used for near/far clustering), which is
        what lets scanning run WITHOUT any location permission on 12+.
        BLUETOOTH_CONNECT is not needed for advertise/scan but is
        declared now so the upcoming GATT credential/state exchange
        doesn't force consumers through a second permission rollout —
        all three land in the same single "Nearby devices" dialog.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!--
        Legacy stack (API ≤ 30): install-time BLUETOOTH/BLUETOOTH_ADMIN,
        plus runtime ACCESS_FINE_LOCATION — those OS versions gate BLE
        scan *results* on it. maxSdkVersion keeps the location permission
        out of the manifest (and off the Play listing's data-safety
        radar) on every modern device.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <!--
        `extractNativeLibs="false"`: native libraries (libnode.so + every
        per-addon `lib<name>__<version>.so` in `jniLibs/<abi>/`) ship
        uncompressed and aligned inside the APK and Bionic mmaps them in
        place at load time — no extraction to nativeLibraryDir. Required
        by the rolled-up backend's bare-name `process.dlopen` calls; a
        full-path dlopen would fail because nativeLibraryDir is empty
        under this configuration. Pairs with
        `packagingOptions.jniLibs.useLegacyPackaging = false` in
        build.gradle.

        `dataExtractionRules` (Android 12+) and `fullBackupContent` (older)
        exclude the SharedPreferences file the rootkey envelope lives in
        from cloud backup and device-to-device transfer.

        **Manifest-merger conflict if the host app already declares these
        attributes.** This is intentional — a silent loss of the exclusion
        would leak a useless-but-private blob to Google Drive backups and
        produce confusing restore UX (envelope restored, wrapper key
        alias missing on the new device, RootKeyException at first
        launch). The build-time error is the lesser evil.

        Resolution path for consumers with existing backup rules:

          1. Merge the contents of `@xml/comapeo_data_extraction_rules`
             and `@xml/comapeo_backup_rules` into your app's own rules
             XML (an `<exclude>` for the `comapeo-core.xml`
             SharedPreferences file under both `<cloud-backup>` and
             `<device-transfer>`).
          2. Add `tools:replace="android:dataExtractionRules,
             android:fullBackupContent"` to your app's `<application>`
             tag. The host's now-merged rules win; the library
             declaration becomes a no-op.

        The actual cryptographic risk of skipping the exclusion is small:
        the wrapper key is device-bound (AndroidKeyStore, non-exportable),
        so a backed-up envelope is useless on any other device. The
        exclusion is defense-in-depth + UX.

        See README "Configure for Android" for the full integration
        guide. A future Expo config plugin (issue tracked separately)
        will automate this for managed-Expo consumers.
    -->
    <application
        android:extractNativeLibs="false"
        android:dataExtractionRules="@xml/comapeo_data_extraction_rules"
        android:fullBackupContent="@xml/comapeo_backup_rules"
        tools:targetApi="s">
        <!--
            Disable sentry-android's `SentryInitProvider` ContentProvider
            auto-init. Init lifecycle is owned explicitly: FGS process
            via `SentryFgsBridge.init` in `ComapeoCoreService.onCreate`;
            main process via `@sentry/react-native`'s native init triggered
            from JS-side `Sentry.init`. Without this opt-out, the
            auto-init provider runs in every process at startup, crashes
            with `DSN is required` in any process where the manifest
            doesn't carry a DSN meta-data (e.g. instrumented test
            processes), and takes the app down before `Application.onCreate`
            finishes. Mirror of the iOS `autoInitializeNativeSdk: false`
            we pass to `Sentry.init` in `src/sentry.ts`.
        -->
        <meta-data android:name="io.sentry.auto-init" android:value="false" />
        <!-- android:name should not change (see http://android-developers.blogspot.com/2011/06/things-that-cannot-change.html) -->
        <!-- android:process is used to run the service in a separate process -->
        <!-- android:exported stops other apps from starting this service -->
        <!-- android:foregroundServiceType see https://developer.android.com/develop/background-work/services/fgs/service-types#data-sync -->
        <service
            android:name=".ComapeoCoreService"
            android:process=":ComapeoCore"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>
    </application>
</manifest>
