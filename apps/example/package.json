{
  "name": "core-react-native-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "expo run:android --variant release --no-install",
    "e2e:android": "../e2e/run-e2e.sh",
    "test:android": "../e2e/run-instrumented-tests.sh",
    "test:android:unit": "../e2e/run-instrumented-tests.sh --unit-only",
    "test:ios": "cd ios && xcodebuild test -workspace corereactnativeexample.xcworkspace -scheme corereactnativeexample -sdk iphonesimulator -destination 'platform=iOS Simulator,name=iPhone 16,OS=latest' CODE_SIGNING_ALLOWED='NO'"
  },
  "dependencies": {
    "@sentry/react-native": "^8.13.0",
    "babel-preset-expo": "~56.0.0",
    "expo": "^56.0.12",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@types/react": "19.2.14",
    "typescript": "5.9.3"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "nativeModulesDir": "../.."
    },
    "install": {
      "exclude": [
        "@sentry/react-native",
        "typescript"
      ]
    }
  },
  "allowScripts": {
    "@sentry/cli": false
  }
}
